# MySQL (docker compose up -d)
MYSQL_ROOT_PASSWORD=tripfit
MYSQL_DATABASE=tripfit
MYSQL_PORT=3306

# Spring Boot — bootRun(local)이 Docker MySQL에 접속
MYSQL_HOST=localhost
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=tripfit

APP_PORT=8080
APP_PUBLISH_HOST=127.0.0.1

# Nginx API 게이트웨이 (docker compose --profile edge --profile app)
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
CERTBOT_DOMAIN=api.tripfit.online

# Auth (docs/specs/auth-social-login.md — access 2h · refresh 30d)
JWT_SECRET=local-dev-secret-must-be-at-least-32-chars
JWT_ACCESS_EXPIRATION=7200
JWT_REFRESH_EXPIRATION_DAYS=30
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID_IOS=
GOOGLE_CLIENT_ID_ANDROID=
APPLE_CLIENT_ID=