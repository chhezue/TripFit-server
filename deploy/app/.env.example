# ============================================================
# EC2 A — Spring Boot API 설정 (GHCR pull, 원격 MySQL)
# ============================================================

# EC2 B private IP (같은 VPC). public IP는 dev 임시 점검용만.
MYSQL_HOST=<EC2 B private IP>
MYSQL_PORT=3306
MYSQL_DATABASE=tripfit

APP_PORT=8080
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
SPRING_PROFILES_ACTIVE=dev

# TLS (scripts/init-letsencrypt.sh)
CERTBOT_DOMAIN=api.tripfit.online
CERTBOT_EMAIL=codus5068@naver.com

# GHCR (private 패키지)
GHCR_IMAGE=ghcr.io/central-makeus/tripfit-server:latest

# JWT (Phase 1 auth — docs/specs/auth-social-login-mvp.md)
JWT_SECRET=<256bit+ random secret>
JWT_ACCESS_EXPIRATION=3600
JWT_REFRESH_EXPIRATION_DAYS=14

# OAuth provider client IDs (token aud 검증)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID_IOS=
GOOGLE_CLIENT_ID_ANDROID=
APPLE_CLIENT_ID=