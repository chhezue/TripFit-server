# EC2 B private IP (같은 VPC). public IP는 dev 임시용만.
MYSQL_HOST=172.31.37.134
MYSQL_PORT=3306
MYSQL_DATABASE=tripfit

# DB 접속 정보는 GitHub Secrets로 관리
# SPRING_DATASOURCE_USERNAME
# SPRING_DATASOURCE_PASSWORD

APP_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# GHCR (private) — 수동 배포 시 login 필요
#   export GHCR_USERNAME=<PAT 만든 GitHub 아이디>
#   export GHCR_PAT=<classic PAT, read:packages>
# CD는 GitHub Secrets: GHCR_PAT, GHCR_USERNAME
GHCR_IMAGE=ghcr.io/central-makeus/tripfit-server:latest
